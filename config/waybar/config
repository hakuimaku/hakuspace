        }
    },

    "hyprland/window": {
        "format": "{}",
        "expand": false,
        "icon": true,
        "icon-size": 24
    },

    "memory": {
        "interval": 15,
        "format": "ţ┐ů {used:0.1f}/{total:0.1f}"
    },

    "cpu": {
        "interval": 5,
        "format": "´őŤ {usage}%"
    },

    "custom/notification": {
    "tooltip": false,
    "format": "{icon}",
    "format-icons": {
        "notification": "´éó<span foreground='red'><sup>´Ĺä</sup></span> ",
        "none": "´éó ",
        "dnd-notification": "´çĚ<span foreground='red'><sup>´Ĺä</sup></span> ",
        "dnd-none": "´çĚ ",
        "inhibited-notification": "´éó<span foreground='red'><sup>´Ĺä</sup></span> ",
        "inhibited-none": "´éó ",
        "dnd-inhibited-notification": "´çĚ<span foreground='red'><sup>´Ĺä</sup></span> ",
        "dnd-inhibited-none": "´çĚ "
        },
        "return-type": "json",
        "exec-if": "which swaync-client",
        "exec": "swaync-client -swb",
        "on-click": "swaync-client -t -sw",
        "on-click-right": "swaync-client -d -sw",
        "escape": true
    },

    "custom/recorder": {
      "exec": "if [ -f /tmp/recording_time ]; then cat /tmp/recording_time; fi",
       "interval": 1,
       "format": "ˇ░Ĺő {}",
      "tooltip": false,
       "return-type": "plain",
       "if-file-exists": "/tmp/recording_pid"
    },

    "backlight": {
        "device": "intel_backlight",
        "format": "{icon} {percent}%",
        "format-icons": ["ţÄŹ", "ţĆô", "ţĆĹ", "ţĆĆ", "ţĆÄ", "ţĆŹ", "ţĆŐ", "ţĆł", "ţÄŤ"],
        "on-scroll-up": "brightnessctl set 1%+",
        "on-scroll-down": "brightnessctl set 1%-",
        "min-length": 6,
        "on-click": "hyprsunset --temperature 3000",
        "on-click-right": "pkill hyprsunset"
    },

    "power-profiles-daemon": {
    "format": "{icon} ",
    "tooltip-format": "Power profile: {profile}\nDriver: {driver}",
    "tooltip": true,
    "format-icons": {
        "default": "ˇ░ŚĹ",
        "performance": "ˇ▒ôč",
        "balanced": "ˇ░ŚĹ",
        "power-saver": "ˇ░î¬"
        }
    },

    /* Note: You should configure timezone and locale to make the clock work properly. */
    "clock": {
        "timezone": "Asia/Ho_Chi_Minh",
        "locale": "vi_VN.UTF-8",
        "format": " {:%A, %d/%m/%Y [ %H:%M:%S ]} ", 
        "interval": 1,
        "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>",
        "calendar": {
            "mode": "month",
            "on-scroll": 1,
            "format": {
                "months": "<span color='#ffead3'><b>{}</b></span>",
                "days": "<span color='#ecc6d9'><b>{}</b></span>",
                "weeks": "<span color='#99ffdd'><b>W{}</b></span>",
                "weekdays": "<span color='#ffcc66'><b>{}</b></span>",
                "today": "<span color='#FF003C'><b><u>{}</u></b></span>"
            }
        },
        "on-click": "~/.local/bin/quick_settings"
    },

    "battery": {
        "states": {
            "warning": 30,
            "critical": 15
        },
        "format": "{icon} {capacity}%",
        "format-charging": "ˇ▒ŐŽ {capacity}%",
        "format-plugged": "´çŽ {capacity}%",
        "format-icons": ["´ëä", "´ëâ", "´ëé", "´ëü", "´ëÇ"]
    },

    "pulseaudio": {
        "format": "{icon} {volume}%",
        "format-muted": "ˇ░Łč Muted",
        "format-icons": {
            "headphone": "´Çą",
            "default": ["´ÇŽ", "´Çž", "´ÇĘ"]
        },
        "on-click": "wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle",
        "on-click-right": "pavucontrol"
    },

    "tray": {
        "icon-size": 15,
        "spacing": 10,
        "show-passive-items": true
    }
}
