{
    "layer": "top",
    "position": "left",
    "margin-top": 0,
    "margin-bottom": 0,
    "margin-left": 0,
    "margin-right": 0,
    "spacing": 2,
    "tooltip": true,

    "modules-left": [
        "custom/haku",
        "hyprland/workspaces"
    ],
    "modules-center": [
        "clock"
    ],
    "modules-right": [
        "custom/recorder",
        "battery",
        "pulseaudio",
        "pulseaudio/slider",
        "backlight",
        "backlight/slider",
        "custom/notification",
        "tray"
    ],

    "clock": {
        "timezone": "Asia/Ho_Chi_Minh",
        "locale": "vi_VN.UTF-8",
        "format": " {:%A, %d/%m/%Y [ %H:%M:%S ]} ", 
        "interval": 1,
        "rotate": 90,
        "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>",
        "calendar": {
            "mode": "month",
            "on-scroll": 1,
            "format": {
                "months": "<span color='#ffead3'><b>{}</b></span>",
                "days": "<span color='#ecc6d9'><b>{}</b></span>",
                "weeks": "<span color='#99ffdd'><b>W{}</b></span>",
                "weekdays": "<span color='#ffcc66'><b>{}</b></span>",
                "today": "<span color='#FF003C'><b><u>{}</u></b></span>"
            }
        }
    },

    "custom/haku": {
        "format": "{icon}",
        "format-icons": {
            "default": "ïچ™"
        },
        "on-click": "~/.local/bin/hakumenu",
        "tooltip-format": "Have a nice day!",
        "tooltip": true
    },

    "custom/notification": {
        "tooltip": true,
        "format": "{icon}",
        "format-icons": {
            "notification": "َ°‚ڑ<span foreground='red'><sup>ï‘„</sup></span>",
            "none": "َ°‚ڑ",
            "dnd-notification": "ï‡¶<span foreground='red'><sup>ï‘„</sup></span>",
            "dnd-none": "ï‡¶",
            "inhibited-notification": "َ°‚ڑ<span foreground='red'><sup>ï‘„</sup></span>",
            "inhibited-none": "َ°‚ڑ",
            "dnd-inhibited-notification": "َ°‚›<span foreground='red'><sup>ï‘„</sup></span>",
            "dnd-inhibited-none": "ï‡¶"
        },
        "return-type": "json",
        "exec-if": "which swaync-client",
        "exec": "swaync-client -swb",
        "on-click": "swaync-client -t -sw",
        "on-click-right": "swaync-client -d -sw",
        "escape": true
    },

    "custom/recorder": {
        "exec": "if [ -f /tmp/recording_time ]; then cat /tmp/recording_time; fi",
        "interval": 1,
        "format": "َ°‘‹",
        "tooltip": false,
        "return-type": "plain",
        "if-file-exists": "/tmp/recording_pid"
    },

    "backlight": {
        "format": "{icon}",
        "format-icons": ["îژچ", "îڈ“", "îڈ‘", "îڈڈ", "îڈژ", "îڈچ", "îڈٹ", "îڈˆ", "îژ›"],
        "on-scroll-up": "brightnessctl set 1%+",
        "on-scroll-down": "brightnessctl set 1%-",
        "on-click": "hyprsunset --temperature 3000",
        "on-click-right": "pkill hyprsunset",
        "tooltip-format": "Brightness: {percent}%"
    },

    "backlight/slider": {
        "min": 10,
        "max": 100,
        "orientation": "vertical"
    },

    "battery": {
        "states": {
            "warning": 30,
            "critical": 15
        },
        "format": "{icon}",
        "format-icons": {
            "default": ["َ°‚ژ", "َ°پ؛", "َ°پ»", "َ°پ¼", "َ°پ½", "َ°پ¾", "َ°پ؟", "َ°‚€", "َ°‚پ", "َ°‚‚", "َ°پ¹"],
            "charging": ["َ°¢ں", "َ°¢œ", "َ°‚†", "َ°‚‡", "َ°‚ˆ", "َ°¢‌", "َ°‚‰", "َ°¢‍", "َ°‚ٹ", "َ°‚‹", "َ°‚…"]
        },
        "tooltip-format": "Battery: {capacity}%\nPower: {power}W\n{timeTo}",
        "tooltip": true
    },

    "pulseaudio": {
        "format": "{icon}",
        "format-muted": "َ°‌ں ",
        "format-icons": {
            "headphone": "َ°‹‹",
            "default": ["ï€¦", "ï€§", "ï€¨"]
        },
        "on-click": "wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle",
        "on-click-right": "pavucontrol",
        "tooltip-format": "Volume: {volume}%"
    },

    "pulseaudio/slider": {
        "min": 0,
        "max": 100,
        "orientation": "vertical"
    },

    "tray": {
        "icon-size": 18,
        "spacing": 10,
        "show-passive-items": true
    },

    "hyprland/workspaces": {
