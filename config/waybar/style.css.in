/* ============================================================================== */
/* GLOBAL STYLES                                  */
/* ============================================================================== */
* {
    font-family: "${FONT_FAMILY}";
    font-size: 16px;
    font-weight: bold;
    border-radius: 20px;
}

window#waybar {
    background-color: transparent;
    color: ${ACCENT_COLOR};
    transition: background-color 0.3s ease;
}

.modules-left, .modules-center, .modules-right {
    background-color: rgba(0, 0, 0, 0.8);
    border-radius: 20px;
    padding: 2px;
    margin: 2px;
}

/* ============================================================================== */
/* COMMON MODULE STYLES                               */
/* ============================================================================== */
#hyprland-workspaces,
#window,
#custom-recorder,
#custom-notification,
#pulseaudio,
#backlight,
#battery,
#tray,
#clock,
#cpu,
#power-profiles-daemon {
    margin: 2px;
    padding: 0 8px;
    transition: all 1s cubic-bezier(0, 0.5, 0.35, 1);
    min-width: 50px;
}

/* ============================================================================== */
/* WORKSPACES                                    */
/* ============================================================================== */
#workspaces button {
    color: ${ACCENT_COLOR};
    padding: 0 12px;
    transition: all 0.7s cubic-bezier(0, 0.5, 0.35, 1);
    margin: 2px;
}

#workspaces button.active {
    color: #000000;
    background-color: ${ACCENT_COLOR};
    transition: all 0.4s cubic-bezier(0, 0.5, 0.35, 1);
    min-width: 70px;
}

#workspaces button.empty {
    color: rgba(0, 0, 0, 1);
}

/*
#workspaces button:nth-child(1):not(.empty):not(.active) {
    color: #ffffff;
}

#workspaces button:nth-child(2):not(.empty):not(.active) {
    color: #ffffff;
}

#workspaces button:nth-child(3):not(.empty):not(.active) {
    color: #ffffff;
}

#workspaces button:nth-child(4):not(.empty):not(.active) {
    color: #ffffff;
}

#workspaces button:nth-child(5):not(.empty):not(.active) {
    color: #ffffff;
}
*/
/* ============================================================================== */
/* SPECIFIC MODULES                                 */
/* ============================================================================== */
#window { color: ${ACCENT_COLOR}; }

#clock { 
    color: ${ACCENT_COLOR}; 
}

#custom-recorder {
    color: ${ACCENT_COLOR};
    border: 1px solid ${ACCENT_COLOR};
    animation: blink 1s infinite; 
}

#custom-notification { color: ${ACCENT_COLOR}; }

#backlight { color: ${ACCENT_COLOR}; }

#pulseaudio { color: ${ACCENT_COLOR}; }

#battery { color: ${ACCENT_COLOR}; }

#memory { color: ${ACCENT_COLOR}; }

#cpu { color: ${ACCENT_COLOR}; }
/* ============================================================================== */
/* HOVER EFFECTS                                   */
/* ============================================================================== */
#power-profiles-daemon:hover,
#workspaces button:hover,
#pulseaudio:hover,
#backlight:hover,
#battery:hover,
#custom-notification:hover,
#memory:hover,
#cpu:hover {
    color: #000000;
    background-color: ${ACCENT_COLOR};
    transition: all 0.4s cubic-bezier(0, 0.5, 0.35, 1);
    min-width: 100px;
}

#clock:hover {
    color: #000000;
    background-color: ${ACCENT_COLOR};
    transition: all 0.4s cubic-bezier(0, 0.5, 0.35, 1);
    min-width: 450px;
}

/* ============================================================================== */
/* TOOLTIPS                                     */
/* ============================================================================== */
tooltip {
    background: rgba(0, 0, 0, 1);
    border-radius: 12px;
    padding: 10px;
}

tooltip label {
    color: ${ACCENT_COLOR};
    font-size: 16px;
}

/* ============================================================================== */
/* ANIMATIONS                                    */
/* ============================================================================== */
@keyframes blink {
    0% { opacity: 1; }
    50% { opacity: 0.5; }
    100% { opacity: 1; }
}
