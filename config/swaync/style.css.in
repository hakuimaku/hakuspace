* {
    font-family: "${FONT_FAMILY}", monospace;
    font-size: ${FONT_SIZE}px;
    font-weight: bold;
}

.notification-row {
    outline: none;
    margin: 5px;
}

.notification {
    background: rgba(0, 0, 0, 1);
    border: 1px solid #000000;
    border-radius: 12px;
    padding: 10px;
    box-shadow: 0 0 5px #000000;
}

.notification-content .summary {
    color: ${ACCENT_COLOR};
    font-size: 16px;
    font-weight: bold;
    text-shadow: 0 0 2px ${ACCENT_COLOR};
}

.notification-content .body {
    color: ${ACCENT_COLOR};
    font-size: 14px;
}

.notification-content .time {
    color: #a6adc8;
}

.notification-action {
    color: #11111b;
    background: ${ACCENT_COLOR};
    border-radius: 5px;
}

/* --- CONTROL CENTER --- */
.control-center {
    background: rgba(0, 0, 0, 1);
    border-radius: 15px;
    box-shadow: 0 0 10px #000000;
    margin: 3px;
}

.widget-title {
    color: ${ACCENT_COLOR};
    font-weight: bold;
    font-size: 1.2rem;
}

.widget-label {
    color: ${ACCENT_COLOR};
}

.widget-buttons-grid > flowbox > flowboxchild > button {
    background: ${ACCENT_COLOR};
    border-radius: 10px;
    margin: 3px;
    border: 1px solid ${ACCENT_COLOR};
}

.widget-buttons-grid > flowbox > flowboxchild > button:hover {
    background: ${ACCENT_COLOR};
    color: ${ACCENT_COLOR};
}

.widget-dnd {
    color: ${ACCENT_COLOR};
}

.widget-dnd > switch {
    background: ${ACCENT_COLOR};
    border-radius: 10px;
    border: 1px solid ${ACCENT_COLOR};
}

.widget-dnd > switch:checked {
    background: ${ACCENT_COLOR};
}