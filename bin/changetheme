#!/usr/bin/env bash
set -euo pipefail

ENVCONF="$HOME/.config/hypr/env.lua"
fonts="$(fc-list : family | sed 's/,.*//' | sort -u)"

# Rofi to select font family
font="$(echo "$fonts" | rofi -dmenu -p "Choose Font Family" -i)"
[ -z "$font" ] && echo "Cancel" && exit 1

# Get current font size from env.lua, default to 16 if not found or invalid
size=$(awk -F'"' '/FONT_SIZE/ {print $3}' "$ENVCONF" 2>/dev/null | grep -o '[0-9][0-9]*' | head -n1 || echo "16")
size=$(echo "$size" | rofi -dmenu -p "Type Font Size"  -i)
[[ "$size" =~ ^[0-9]+$ ]] || size="16"

# Escape font name
font_escaped="${font//\"/\\\"}"

# Update env.lua
if [[ -f "$ENVCONF" ]]; then
    sed -i \
        -e "s/hl.env(\"FONT_FAMILY\".*/hl.env(\"FONT_FAMILY\", \"$font_escaped\")/" \
        -e "s/hl.env(\"FONT_SIZE\".*/hl.env(\"FONT_SIZE\", $size)/" \
        "$ENVCONF"
else
    cat >"$ENVCONF" <<EOF
hl.env("FONT_FAMILY", "$font_escaped")
hl.env("FONT_SIZE", $size)
EOF
fi

~/.local/bin/updatetheme

hyprctl reload
pkill swaync && swaync &
pkill waybar && waybar &

notify-send "Hyprland Theme Updated" "Font: $font, Size: $size"