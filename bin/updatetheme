#!/usr/bin/env bash
set -euo pipefail

ENVCONF="$HOME/.config/hypr/env.lua"

DEFAULT_FONT_FAMILY="monospace"
DEFAULT_FONT_SIZE="16"

mkdir -p "$(dirname "$ENVCONF")"

create_default_envconf() {
    cat >"$ENVCONF" <<EOF
# Generated by updatetheme
hl.env("FONT_FAMILY", "${DEFAULT_FONT_FAMILY}")
hl.env("FONT_SIZE", ${DEFAULT_FONT_SIZE})
EOF
}

# 1) Ensure env.lua exists
if [[ ! -f "$ENVCONF" ]]; then
    create_default_envconf
fi

# 2) Parse env.lua format: hl.env("KEY", VALUE)
#    - ignore blank lines and comment-only lines
#    - ignore malformed lines
#    - accept spaces around tokens
#    - strip trailing comments (anything after --)
unset FONT_FAMILY FONT_SIZE

while IFS= read -r line; do
    # Trim leading/trailing whitespace
    line="${line#"${line%%[![:space:]]*}"}"
    line="${line%"${line##*[![:space:]]}"}"
    [[ -z "$line" ]] && continue
    [[ "$line" == \#* ]] && continue
    [[ "$line" == --* ]] && continue

    # Remove trailing comments: " ... -- comment"
    line="${line%%--*}"
    line="${line%"${line##*[![:space:]]}"}"
    [[ -z "$line" ]] && continue

    # Only handle hl.env("KEY", VALUE)
    parsed="$(printf '%s\n' "$line" | sed -nE 's/^hl\.env[[:space:]]*\([[:space:]]*"([^"]+)"[[:space:]]*,[[:space:]]*(.+)[[:space:]]*\)$/\1|\2/p')"
    [[ -z "$parsed" ]] && continue

    key="${parsed%%|*}"
    val="${parsed#*|}"

    # Remove optional wrapping quotes around string values.
    if [[ "$val" =~ ^\"(.*)\"$ ]]; then
        val="${BASH_REMATCH[1]}"
    fi

    case "$key" in
        FONT_FAMILY) FONT_FAMILY="$val" ;;
        FONT_SIZE)   FONT_SIZE="$val" ;;
    esac
done < "$ENVCONF"

# 3) Apply defaults if missing
: "${FONT_FAMILY:=$DEFAULT_FONT_FAMILY}"
: "${FONT_SIZE:=$DEFAULT_FONT_SIZE}"

# 4) Validate FONT_SIZE is integer > 0
if ! [[ "$FONT_SIZE" =~ ^[0-9]+$ ]] || [[ "$FONT_SIZE" -le 0 ]]; then
    echo "WARN: FONT_SIZE='$FONT_SIZE' invalid -> fallback to $DEFAULT_FONT_SIZE" >&2
    FONT_SIZE="$DEFAULT_FONT_SIZE"
fi

# 5) Validate FONT_FAMILY exists (fontconfig).
#    If fontconfig not available, we skip the existence check.
if command -v fc-match >/dev/null 2>&1; then
    # fc-match always returns something; compare matched family with requested.
    matched="$(fc-match -f '%{family}\n' "$FONT_FAMILY" 2>/dev/null | head -n1 || true)"
    if [[ -z "$matched" ]]; then
        echo "WARN: fc-match failed for FONT_FAMILY='$FONT_FAMILY' -> fallback to $DEFAULT_FONT_FAMILY" >&2
        FONT_FAMILY="$DEFAULT_FONT_FAMILY"
    else
        # Heuristic: if the match doesn't include requested family, consider not found.
        if [[ "${matched,,}" != *"${FONT_FAMILY,,}"* ]]; then
            echo "WARN: FONT_FAMILY='$FONT_FAMILY' not found (matched: $matched) -> fallback to $DEFAULT_FONT_FAMILY" >&2
            FONT_FAMILY="$DEFAULT_FONT_FAMILY"
        fi
    fi
fi

# 6) If we had to fallback because env was missing/invalid, optionally rewrite env.lua
#    so the file reflects the effective config (keeps single source of truth).
rewrite_envconf=false
if [[ "$FONT_FAMILY" == "$DEFAULT_FONT_FAMILY" && "$FONT_SIZE" == "$DEFAULT_FONT_SIZE" ]]; then
    # If env.lua exists but had garbage/missing keys, we can normalize it.
    # We'll rewrite if it doesn't explicitly contain both keys in correct form.
    if ! grep -qE '^\s*hl\.env\s*\(\s*"FONT_FAMILY"\s*,\s*"[^"]+"\s*\)\s*$' "$ENVCONF" || ! grep -qE '^\s*hl\.env\s*\(\s*"FONT_SIZE"\s*,\s*[0-9]+\s*\)\s*$' "$ENVCONF"; then
        rewrite_envconf=true
    fi
fi

if [[ "$rewrite_envconf" == true ]]; then
    create_default_envconf
fi

GTK_FONT="${FONT_FAMILY} ${FONT_SIZE}"
export FONT_FAMILY FONT_SIZE GTK_FONT

# 7) Generate theme files
~/.local/bin/gen-kitty-style.sh
~/.local/bin/gen-waybar-style.sh
~/.local/bin/gen-rofi-style.sh
~/.local/bin/gen-hyprlock-style.sh
~/.local/bin/gen-swaync-style.sh

# 8) Apply GTK
if command -v gsettings >/dev/null 2>&1; then
    gsettings set org.gnome.desktop.interface font-name "$GTK_FONT" || true
    gsettings set org.gnome.desktop.interface monospace-font-name "$GTK_FONT" || true
else
    echo "WARN: gsettings not found; skipping GTK font update" >&2
fi

echo "Updated theme files with the following settings:"
echo "FONT_FAMILY=$FONT_FAMILY"
echo "FONT_SIZE=$FONT_SIZE"
echo "GTK_FONT=$GTK_FONT"
echo "ENVCONF=$ENVCONF"