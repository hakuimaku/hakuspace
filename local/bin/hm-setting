#!/bin/bash
set -euo pipefail
spawn() { ( "$@" & ) >/dev/null 2>&1; disown; }

if [[ $# -eq 0 ]]; then
  cat <<'EOF'
ó°–©  Wifi
ó°‚¯  Bluetooth
ïƒ‡  Disk Manager
ó°‹Š  Storage Manager
ó°“ƒ  Audio Control
ï€“  Haku Menu Setting
EOF
  exit 0
fi

chosen="$*"
case "$chosen" in
  *"Wifi"*) spawn nm-connection-editor ;;
  *"Bluetooth"*) spawn blueman-manager ;;
  *"Disk Manager"*) spawn gparted ;;
  *"Storage Manager"*) spawn kitty --class ncdu -e sudo ncdu / ;;
  *"Audio Control"*) spawn pavucontrol ;;
  *"Haku Menu Setting"*) spawn code ~/.local/bin/hakumenu ;;
esac

exit 0