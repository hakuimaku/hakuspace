#!/bin/bash
set -euo pipefail

spawn() { ( "$@" & ) >/dev/null 2>&1; disown; }

if [[ $# -eq 0 ]]; then
  cat <<'EOF'
¾░ı£  App Menu
¾░¿Ş  Visual Studio Code
¾░çğ  Browser
¾░æï  Screen Record
´çİ  Local Send
¯¬â  File Manager
¾░ë╗  Hyprland Folder
¾░êå  Quit
EOF
  exit 0
fi

chosen="$*"
case "$chosen" in
  *"App Menu"*) spawn rofi -show drun ;;
  *"Visual Studio Code"*) spawn code ;;
  *"Browser"*) spawn zen-browser ;;
  *"Screen Record"*) spawn ~/.local/bin/record ;;
  *"Local Send"*) spawn localsend ;;
  *"File Manager"*) spawn nemo ;;
  *"Hyprland Folder"*) spawn nemo ~/.config/hypr/ ;;
  *"Quit"*) spawn ~/.local/bin/shutdown ;;
esac

exit 0